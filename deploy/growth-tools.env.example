# Copy this file to a private env file on the host, generate real secrets, then run:
# docker compose --env-file deploy/growth-tools.generated.env -f deploy/docker-compose.growth-tools.yml --profile twenty up -d

POSTIZ_MAIN_URL=http://localhost:4007
POSTIZ_FRONTEND_URL=http://localhost:4007
POSTIZ_BACKEND_URL=http://localhost:4007/api
POSTIZ_JWT_SECRET=replace-with-64-random-characters
POSTIZ_POSTGRES_USER=postiz_user
POSTIZ_POSTGRES_PASSWORD=replace-with-random-password
POSTIZ_POSTGRES_DB=postiz
POSTIZ_TEMPORAL_POSTGRES_PASSWORD=replace-with-random-password
POSTIZ_DISABLE_REGISTRATION=false
POSTIZ_API_LIMIT=30

TWENTY_TAG=latest
TWENTY_SERVER_URL=http://localhost:4019
TWENTY_POSTGRES_USER=twenty_user
TWENTY_POSTGRES_PASSWORD=replace-with-random-password
TWENTY_POSTGRES_DB=twenty
TWENTY_ENCRYPTION_KEY=replace-with-32-random-bytes-or-valid-key
TWENTY_FALLBACK_ENCRYPTION_KEY=replace-with-32-random-bytes-or-valid-key
TWENTY_APP_SECRET=replace-with-random-app-secret

MAUTIC_MYSQL_ROOT_PASSWORD=replace-with-random-root-password
MAUTIC_MYSQL_DATABASE=mautic
MAUTIC_MYSQL_USER=mautic_user
MAUTIC_MYSQL_PASSWORD=replace-with-random-password
MAUTIC_LOAD_TEST_DATA=false
